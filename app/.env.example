VITE_SUPABASE_URL=your_value_here
VITE_SUPABASE_ANON_KEY=your_value_here
VITE_CHECKOUT_WEBHOOK_URL=your_value_here

# Public blog (see app/scripts/generate-blog-static.mjs)
VITE_SITE_URL=https://shortyharris.com
VITE_GA_MEASUREMENT_ID=your_value_here

# NOT a VITE_ var — this must stay server-side only (Supabase Edge Function
# secret, not a build-time env var), since VITE_-prefixed values get baked
# into the public JS bundle and anyone with the deploy hook URL can trigger
# a rebuild. Set it with:
#   supabase secrets set VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy-hooks/...
